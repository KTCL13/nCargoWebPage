# ============================================================
# N-Cargo — Variables de entorno requeridas
# Copiar este archivo como .env y completar los valores reales
# ============================================================

# Base de datos PostgreSQL (Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# JWT — generar con: openssl rand -base64 48
JWT_SECRET="CHANGE_ME"

# Transactional email (Resend)
RESEND_API_KEY="re_XXXXXXXXXXXXXXXXXXXXXXXX"

# URL pública de la aplicación
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Strapi CMS (opcional)
NEXT_PUBLIC_STRAPI_URL="http://localhost:1337"
STRAPI_API_TOKEN="STRAPI_TOKEN_HERE"

# Odoo ERP
ODOO_URL="https://YOUR_INSTANCE.odoo.com"
ODOO_DB="YOUR_DB"
ODOO_USERNAME="user@example.com"
ODOO_API_KEY="ODOO_API_KEY_HERE"

# Referencia interna del producto de envío en Odoo
ODOO_SHIPPING_PRODUCT_CODE="ENVIO_INTERNACIONAL"

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =======================
// Employee Domain
// =======================
model Employee {
  id             Int                 @id @default(autoincrement())
  name           String              @db.VarChar(150)
  email          String              @unique @db.VarChar(255)
  status         EmployeeStatus      @default(ACTIVE)
  timezone       String              @default("America/Bogota")
  metadata       Json?
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  passwordHash   String?             @map("password_hash") @db.VarChar(255)
  attendances         Attendance[]
  tasks               Task[]              @relation("EmployeeTasks")
  assignedTasks       Task[]              @relation("AssignedByEmployee")
  auditLogs           AuditLog[]
  contracts           Contract[]
  alerts              EmployeeAlert[]
  kpis                EmployeeKPI[]
  employeeRoles       EmployeeRole[]
  documents           GeneratedDocument[]
  jobHistory          JobHistory[]
  notifications       Notification[]
  quotations          Quotation[]
  shipmentEvents      ShipmentEvent[]
  taskAnalytics       TaskAnalytics[]
  sessions            UserSession[]
  workloads           WorkloadSnapshot[]
  passwordResetTokens PasswordResetToken[]
  cotizacionRecords   CotizacionRecord[]

  @@map("employees")
}

model Job {
  id          Int          @id @default(autoincrement())
  title       String       @db.VarChar(150)
  description String?
  contracts   Contract[]
  jobHistory  JobHistory[]

  @@map("jobs")
}

model ContractType {
  id        Int        @id @default(autoincrement())
  name      String     @unique @db.VarChar(100)
  contracts Contract[]

  @@map("contract_types")
}

model Contract {
  id             Int          @id @default(autoincrement())
  employeeId     Int          @map("employee_id")
  jobId          Int          @map("job_id")
  contractTypeId Int          @map("contract_type_id")
  salary         Decimal?     @db.Decimal(12, 2)
  hourlyRate     Decimal?     @map("hourly_rate") @db.Decimal(10, 2)
  startDate      DateTime     @map("start_date")
  endDate        DateTime?    @map("end_date")
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  contractType   ContractType @relation(fields: [contractTypeId], references: [id])
  employee       Employee     @relation(fields: [employeeId], references: [id])
  job            Job          @relation(fields: [jobId], references: [id])
  jobHistory     JobHistory[]

  @@map("contracts")
}

model JobHistory {
  id         Int       @id @default(autoincrement())
  employeeId Int       @map("employee_id")
  contractId Int       @map("contract_id")
  jobId      Int       @map("job_id")
  startDate  DateTime  @map("start_date")
  endDate    DateTime? @map("end_date")
  contract   Contract  @relation(fields: [contractId], references: [id])
  employee   Employee  @relation(fields: [employeeId], references: [id])
  job        Job       @relation(fields: [jobId], references: [id])

  @@map("job_history")
}

// =======================
// Authorization
// =======================
model Role {
  id            Int            @id @default(autoincrement())
  name          String         @unique @db.VarChar(50)
  employeeRoles EmployeeRole[]

  @@map("roles")
}

model EmployeeRole {
  employeeId Int      @map("employee_id")
  roleId     Int      @map("role_id")
  employee   Employee @relation(fields: [employeeId], references: [id])
  role       Role     @relation(fields: [roleId], references: [id])

  @@id([employeeId, roleId])
  @@map("employee_roles")
}

// =======================
// Task Management
// =======================
model TaskStatus {
  id    Int    @id @default(autoincrement())
  name  String @unique @db.VarChar(50)
  tasks Task[]

  @@map("task_status")
}

model Task {
  id           Int        @id @default(autoincrement())
  employeeId   Int        @map("employee_id")
  createdBy    Int        @map("created_by")
  assignedBy   Int?       @map("assigned_by")
  attendanceId Int?       @map("attendance_id")
  statusId     Int        @map("status_id")
  title        String     @db.VarChar(255)
  description  String?    @db.Text
  metadata     Json?
  startTime    DateTime?  @map("start_time")
  endTime      DateTime?  @map("end_time")
  minutesSpent Int?       @map("minutes_spent")
  createdAt    DateTime   @default(now()) @map("created_at")

  employee           Employee        @relation("EmployeeTasks", fields: [employeeId], references: [id])
  attendance         Attendance?     @relation(fields: [attendanceId], references: [id])
  status             TaskStatus      @relation(fields: [statusId], references: [id])
  assignedByEmployee Employee?       @relation("AssignedByEmployee", fields: [assignedBy], references: [id])
  taskAnalytics      TaskAnalytics[]

  @@map("tasks")
}

// =======================
// Attendance System
// =======================
model Attendance {
  id          Int               @id @default(autoincrement())
  employeeId  Int               @map("employee_id")
  status      AttendanceStatus  @default(OPEN)
  timezone    String            @default("America/Bogota")
  startedAt   DateTime          @map("started_at")
  endedAt     DateTime?         @map("ended_at")
  workedHours Decimal?          @map("worked_hours") @db.Decimal(5, 2)
  employee    Employee          @relation(fields: [employeeId], references: [id])
  events      AttendanceEvent[]
  tasks       Task[]

  @@map("attendance")
}

model AttendanceEvent {
  id               Int                 @id @default(autoincrement())
  attendanceId     Int                 @map("attendance_id")
  type             AttendanceEventType
  timestamp        DateTime            @default(now())
  locationMetadata Json?               @map("location_metadata")
  createdAt        DateTime            @default(now()) @map("created_at")
  attendance       Attendance          @relation(fields: [attendanceId], references: [id])

  @@map("attendance_events")
}

// =======================
// Sessions
// =======================
model UserSession {
  id         Int       @id @default(autoincrement())
  employeeId Int       @map("employee_id")
  loginAt    DateTime  @default(now()) @map("login_at")
  logoutAt   DateTime? @map("logout_at")
  ipAddress  String?   @map("ip_address") @db.VarChar(45)
  deviceInfo Json?     @map("device_info")
  employee   Employee  @relation(fields: [employeeId], references: [id])

  @@map("user_sessions")
}

// =======================
// Location (Recursive: Country -> Department -> City)
// =======================
model Location {
  id        Int        @id @default(autoincrement())
  name      String     @db.VarChar(100)
  type      String     @db.VarChar(20)  // 'COUNTRY', 'DEPARTMENT', 'CITY'
  zipCode   String?    @map("zip_code") @db.VarChar(20)
  parentId  Int?       @map("parent_id")
  parent    Location?  @relation("LocationHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  Location[] @relation("LocationHierarchy")
  
  offices           Office[]
  shippingRates     ShippingRate[]
  quotations        Quotation[]
  cotizacionRecords CotizacionRecord[]

  @@map("locations")
}

// =======================
// Office (reemplaza PickupPoint)
// =======================
model Office {
  id                  Int         @id @default(autoincrement())
  name                String      @db.VarChar(150)
  address             String      @db.VarChar(255)
  latitude            Decimal     @db.Decimal(10, 7)
  longitude           Decimal     @db.Decimal(10, 7)
  coverageRadiusMiles Decimal?    @map("coverage_radius_miles") @db.Decimal(8, 2)
  isActive            Boolean     @default(true) @map("is_active")
  locationId          Int?        @map("location_id")
  location            Location?   @relation(fields: [locationId], references: [id])
  quotations          Quotation[]

  @@map("offices")
}

// =======================
// Shipping
// =======================
model ShippingProvider {
  id            Int            @id @default(autoincrement())
  name          String         @unique @db.VarChar(100)
  shipments     Shipment[]
  shippingRates ShippingRate[]

  @@map("shipping_providers")
}

model ShippingRate {
  id         Int              @id @default(autoincrement())
  providerId Int              @map("provider_id")
  locationId Int              @map("location_id")
  price      Decimal          @db.Decimal(10, 2)
  provider   ShippingProvider @relation(fields: [providerId], references: [id])
  location   Location         @relation(fields: [locationId], references: [id])
  quotations Quotation[]

  @@unique([providerId, locationId])
  @@map("shipping_rates")
}

// =======================
// Quotation
// =======================
model Quotation {
  id                  Int             @id @default(autoincrement())
  employeeId          Int?            @map("employee_id")
  odooCustomerId      Int?            @map("odoo_customer_id")
  odooOrderId         Int?            @map("odoo_order_id")
  odooOrderName       String?         @map("odoo_order_name") @db.VarChar(100)
  originOfficeId      Int?            @map("origin_office_id")
  pickupDistanceMiles Decimal?        @map("pickup_distance_miles") @db.Decimal(10, 2)
  destinationLocationId Int?          @map("destination_location_id")
  shippingRateId      Int?            @map("shipping_rate_id")
  weightLbs           Decimal         @map("weight_lbs") @db.Decimal(8, 2)
  volume              Decimal         @db.Decimal(10, 4)
  declaredValue       Decimal         @map("declared_value") @db.Decimal(12, 2)
  totalPrice          Decimal         @map("total_price") @db.Decimal(12, 2)
  country             String?         @db.VarChar(2)
  source              String          @default("INTERNAL") @db.VarChar(10)
  status              QuotationStatus @default(DRAFT)
  createdAt           DateTime        @default(now()) @map("created_at")

  employee            Employee?     @relation(fields: [employeeId], references: [id])
  originOffice        Office?       @relation(fields: [originOfficeId], references: [id])
  destinationLocation Location?     @relation(fields: [destinationLocationId], references: [id])
  shippingRate        ShippingRate? @relation(fields: [shippingRateId], references: [id])
  shipments           Shipment[]

  @@map("quotations")
}

// =======================
// Shipments
// =======================
model Locker {
  id              Int        @id @default(autoincrement())
  odooProjectId   Int        @unique @map("odoo_project_id")
  odooProjectName String     @map("odoo_project_name") @db.VarChar(255)
  customerName    String?    @map("customer_name") @db.VarChar(255)
  customerEmail   String?    @map("customer_email") @db.VarChar(255)
  lastSyncedAt    DateTime?  @map("last_synced_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  shipments       Shipment[]

  @@map("lockers")
}

model ShipmentStatus {
  id        Int        @id @default(autoincrement())
  name      String     @unique @db.VarChar(100)
  shipments Shipment[]

  @@map("shipment_status")
}

model Shipment {
  id                 Int              @id @default(autoincrement())
  quotationId        Int?             @map("quotation_id")
  providerId         Int              @map("provider_id")
  statusId           Int              @map("status_id")
  odooOrderId        Int?             @map("odoo_order_id")
  odooCustomerId     Int?             @map("odoo_customer_id")
  odooTaskId         Int?             @map("odoo_task_id")
  odooProjectId      Int?             @map("odoo_project_id")
  odooProjectName    String?          @map("odoo_project_name") @db.VarChar(255)
  odooCustomerName   String?          @map("odoo_customer_name") @db.VarChar(255)
  odooStageName      String?          @map("odoo_stage_name") @db.VarChar(100)
  odooTaskName       String?          @map("odoo_task_name") @db.VarChar(255)
  isLocker           Boolean          @default(false) @map("is_locker")
  lockerId           Int?             @map("locker_id")
  locker             Locker?          @relation(fields: [lockerId], references: [id])
  trackingNumber     String?          @map("tracking_number") @db.VarChar(100)
  weightLbs          Decimal?         @map("weight_lbs") @db.Decimal(8, 2)
  receivedAtMailbox  DateTime?        @map("received_at_mailbox")
  pickedByNcargo     DateTime?        @map("picked_by_ncargo")
  handedToProvider   DateTime?        @map("handed_to_provider")
  deliveredAt        DateTime?        @map("delivered_at")
  cancelledAt        DateTime?        @map("cancelled_at")
  cancellationReason String?          @map("cancellation_reason")
  metadata           Json?
  updatedBy          Int?             @map("updated_by")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  events             ShipmentEvent[]
  cotizaciones       CotizacionRecord[]
  provider           ShippingProvider @relation(fields: [providerId], references: [id])
  quotation          Quotation?       @relation(fields: [quotationId], references: [id])
  status             ShipmentStatus   @relation(fields: [statusId], references: [id])

  @@map("shipments")
}

model ShipmentEvent {
  id          Int       @id @default(autoincrement())
  shipmentId  Int       @map("shipment_id")
  status      String    @db.VarChar(100)
  notes       String?
  performedBy Int?      @map("performed_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  employee    Employee? @relation(fields: [performedBy], references: [id])
  shipment    Shipment  @relation(fields: [shipmentId], references: [id])

  @@map("shipment_events")
}

// =======================
// Notifications
// =======================
model Notification {
  id         Int       @id @default(autoincrement())
  employeeId Int?      @map("employee_id")
  type       String    @db.VarChar(100)
  message    String
  read       Boolean   @default(false)
  metadata   Json?
  createdAt  DateTime  @default(now()) @map("created_at")
  employee   Employee? @relation(fields: [employeeId], references: [id])

  @@map("notifications")
}

// =======================
// Generated Documents
// =======================
model GeneratedDocument {
  id          Int       @id @default(autoincrement())
  employeeId  Int?      @map("employee_id")
  type        String    @db.VarChar(100)
  fileUrl     String    @map("file_url") @db.VarChar(500)
  metadata    Json?
  generatedBy Int       @map("generated_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  employee    Employee? @relation(fields: [employeeId], references: [id])

  @@map("generated_documents")
}

// =======================
// Audit Logs
// =======================
model AuditLog {
  id          Int       @id @default(autoincrement())
  entityType  String    @map("entity_type") @db.VarChar(100)
  entityId    Int       @map("entity_id")
  action      String    @db.VarChar(50)
  performedBy Int?      @map("performed_by")
  oldValues   Json?     @map("old_values")
  newValues   Json?     @map("new_values")
  createdAt   DateTime  @default(now()) @map("created_at")
  employee    Employee? @relation(fields: [performedBy], references: [id])

  @@map("audit_logs")
}

// =======================
// System Config
// =======================
model SystemConfig {
  key         String   @id @db.VarChar(100)
  value       Json
  description String?  @db.VarChar(255)
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_config")
}

// =======================
// Employee Analytics
// =======================
model EmployeeKPI {
  id                 Int      @id @default(autoincrement())
  employeeId         Int      @map("employee_id")
  date               DateTime @db.Date
  tasksCompleted     Int      @default(0) @map("tasks_completed")
  tasksPending       Int      @default(0) @map("tasks_pending")
  avgTaskTimeMinutes Decimal? @map("avg_task_time_minutes") @db.Decimal(8, 2)
  totalWorkedHours   Decimal? @map("total_worked_hours") @db.Decimal(5, 2)
  productivityScore  Decimal? @map("productivity_score") @db.Decimal(5, 2)
  createdAt          DateTime @default(now()) @map("created_at")
  employee           Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
  @@map("employee_kpis")
}

model TaskAnalytics {
  id              Int      @id @default(autoincrement())
  taskId          Int      @unique @map("task_id")
  employeeId      Int      @map("employee_id")
  durationMinutes Int?     @map("duration_minutes")
  wasDelayed      Boolean  @default(false) @map("was_delayed")
  createdAt       DateTime @default(now()) @map("created_at")
  employee        Employee @relation(fields: [employeeId], references: [id])
  task            Task     @relation(fields: [taskId], references: [id])

  @@map("task_analytics")
}

model WorkloadSnapshot {
  id             Int      @id @default(autoincrement())
  employeeId     Int      @map("employee_id")
  date           DateTime @db.Date
  activeTasks    Int      @default(0) @map("active_tasks")
  completedTasks Int      @default(0) @map("completed_tasks")
  workloadScore  Decimal? @map("workload_score") @db.Decimal(5, 2)
  createdAt      DateTime @default(now()) @map("created_at")
  employee       Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
  @@map("workload_snapshots")
}

model EmployeeAlert {
  id         Int       @id @default(autoincrement())
  employeeId Int       @map("employee_id")
  type       String    @db.VarChar(100)
  message    String
  severity   String    @db.VarChar(20)
  resolvedAt DateTime? @map("resolved_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  employee   Employee  @relation(fields: [employeeId], references: [id])

  @@map("employee_alerts")
}

// =======================
// Password Reset
// =======================
model PasswordResetToken {
  id         Int       @id @default(autoincrement())
  token      String    @unique @db.VarChar(255)
  employeeId Int       @map("employee_id")
  employee   Employee  @relation(fields: [employeeId], references: [id])
  expiresAt  DateTime  @map("expires_at")
  usedAt     DateTime? @map("used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("password_reset_tokens")
}

// =======================
// Cotizacion Records (public + employee)
// =======================
model CotizacionRecord {
  id                  Int       @id @default(autoincrement())
  country             String    @db.VarChar(2)
  destinationLocationId Int?    @map("destination_location_id")
  heightIn            Decimal   @map("height_in") @db.Decimal(8, 2)
  widthIn             Decimal   @map("width_in") @db.Decimal(8, 2)
  lengthIn            Decimal   @map("length_in") @db.Decimal(8, 2)
  actualWeightLb      Decimal   @map("actual_weight_lb") @db.Decimal(8, 2)
  volumetricWeightLb  Decimal   @map("volumetric_weight_lb") @db.Decimal(8, 2)
  chargeableWeightLb  Decimal   @map("chargeable_weight_lb") @db.Decimal(8, 2)
  declaredValueUsd    Decimal   @map("declared_value_usd") @db.Decimal(12, 2)
  pickupMiles         Decimal?  @map("pickup_miles") @db.Decimal(8, 2)
  transport           Decimal   @db.Decimal(12, 2)
  volumetricSurcharge Decimal   @map("volumetric_surcharge") @db.Decimal(12, 2)
  insurance           Decimal   @db.Decimal(12, 2)
  customs             Decimal   @db.Decimal(12, 2)
  cityDelivery        Decimal   @map("city_delivery") @db.Decimal(12, 2)
  pickup              Decimal   @db.Decimal(12, 2)
  total               Decimal   @db.Decimal(12, 2)
  flatRateApplied     Boolean   @default(false) @map("flat_rate_applied")
  source              String    @default("PUBLIC") @map("source") @db.VarChar(10)
  employeeId          Int?      @map("employee_id")
  shipmentId          Int?      @map("shipment_id")
  createdAt           DateTime  @default(now()) @map("created_at")

  destinationLocation Location?  @relation(fields: [destinationLocationId], references: [id])
  employee            Employee?  @relation(fields: [employeeId], references: [id])
  shipment            Shipment?  @relation(fields: [shipmentId], references: [id])

  @@map("cotizacion_records")
}

// =======================
// Enums
// =======================
enum EmployeeStatus {
  ACTIVE
  INACTIVE

  @@map("employee_status")
}

enum AttendanceStatus {
  OPEN
  PAUSED
  CLOSED

  @@map("attendance_status")
}

enum AttendanceEventType {
  CLOCK_IN
  PAUSE
  RESUME
  CLOCK_OUT

  @@map("attendance_event_type")
}

enum QuotationStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  CANCELLED

  @@map("quotation_status")
}